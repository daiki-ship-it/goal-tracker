# Google Sheets設定
SPREADSHEET_ID=1fYocFASoMyTnxg1S1kvd-0b8spDhTOB5D6x9U-psK_8

# 認証方法: "service_account" または "oauth"
AUTH_METHOD=service_account

# サービスアカウントJSONファイルのパス (AUTH_METHOD=service_accountの場合)
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# OAuthクレデンシャルJSONファイルのパス (AUTH_METHOD=oauthの場合)
GOOGLE_CREDENTIALS_FILE=credentials.json

# ─── Notion カレンダー・タスク連携（「日次記録」ページ・読み取り専用）────────────────
# Notion インテグレーショントークン（https://www.notion.so/my-integrations で作成）
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# カレンダーイベント用 Notion データベース ID（DB を開いた URL の UUID 部分）
# DB にはインテグレーションを「共有」で追加してください
NOTION_CALENDAR_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# イベントの日付プロパティ名（デフォルト: Date）
NOTION_CALENDAR_DATE_PROPERTY=Date

# タスク用 Notion データベース ID（任意。未設定の場合「個人タスク関連」は表示されません）
# NOTION_TASKS_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AIローンチ用 Notion データベース ID（任意。未設定の場合「AIローンチ関連」は表示されません）
# NOTION_AI_LAUNCH_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 「予定・タスク」内の「Notionで開く」リンク先（任意。未設定なら各 DB ID から https://www.notion.so/... を自動生成）
# NOTION_TASKS_WEB_URL=https://www.notion.so/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_AI_LAUNCH_WEB_URL=https://www.notion.so/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# タスクの期限プロパティ名（デフォルト: Due）
# NOTION_TASKS_DATE_PROPERTY=Due

# タスクのステータスプロパティ名（任意。checkbox または status 型に対応）
# NOTION_TASKS_STATUS_PROPERTY=Status

# 月の境界・表示用タイムゾーン
NOTION_CALENDAR_TZ=Asia/Tokyo

# データベースファイルのパス
DATABASE_PATH=goal_tracker.db

# 自動同期時刻 (毎日この時間に同期)
SYNC_HOUR=7
SYNC_MINUTE=0
