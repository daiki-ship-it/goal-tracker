# Google Sheets設定
SPREADSHEET_ID=1fYocFASoMyTnxg1S1kvd-0b8spDhTOB5D6x9U-psK_8

# 認証方法: "service_account" または "oauth"
AUTH_METHOD=service_account

# サービスアカウントJSONファイルのパス (AUTH_METHOD=service_accountの場合)
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# OAuthクレデンシャルJSONファイルのパス (AUTH_METHOD=oauthの場合)
GOOGLE_CREDENTIALS_FILE=credentials.json

# Google Calendar + Tasks（「日次記録」ページ・読み取り専用・個人 OAuth）
# GCP: Calendar API と Tasks API を有効化。デスクトップアプリ OAuth クライアントの JSON をこのパスに置く（Git に含めない）
# タスク連携を追加したあと表示されない場合は token.json を削除して再接続（スコープ再同意）
GOOGLE_CALENDAR_CREDENTIALS_PATH=credentials.json
# 初回ブラウザ認証後に自動作成されるトークン（Git に含めない）
GOOGLE_CALENDAR_TOKEN_PATH=token.json
# 参照カレンダー ID。メインは primary。複数はカンマ区切り（例: primary,xxxx@group.calendar.google.com）
# Google のウェブ画面で複数カレンダーを重ね表示していても、ここに書いた ID だけが API で読まれます。
GOOGLE_CALENDAR_ID=primary
# 月の境界・表示用タイムゾーン
GOOGLE_CALENDAR_TZ=Asia/Tokyo
# 日次記録ページの Google 周りの長い説明・確認用一覧を出す（1 / true / yes / on）。省略時は非表示（すっきり表示）
# GOOGLE_CALENDAR_SHOW_HELP=1

# データベースファイルのパス
DATABASE_PATH=goal_tracker.db

# 自動同期時刻 (毎日この時間に同期)
SYNC_HOUR=7
SYNC_MINUTE=0
