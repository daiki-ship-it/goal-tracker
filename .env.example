# Google Sheets設定
SPREADSHEET_ID=1fYocFASoMyTnxg1S1kvd-0b8spDhTOB5D6x9U-psK_8

# 認証方法: "service_account" または "oauth"
AUTH_METHOD=service_account

# サービスアカウントJSONファイルのパス (AUTH_METHOD=service_accountの場合)
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# OAuthクレデンシャルJSONファイルのパス (AUTH_METHOD=oauthの場合)
GOOGLE_CREDENTIALS_FILE=credentials.json

# データベースファイルのパス
DATABASE_PATH=goal_tracker.db

# 自動同期時刻 (毎日この時間に同期)
SYNC_HOUR=7
SYNC_MINUTE=0
